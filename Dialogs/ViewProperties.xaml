<Window x:Class="Micasa.Dialogs.ViewProperties"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Micasa.Dialogs"
        mc:Ignorable="d"
        Title="View All Raw EXIF Properties" ResizeMode="NoResize" Width="400" Height="485">
    <Grid>  
        <Grid.RowDefinitions>
            <RowDefinition Height="28" />
            <RowDefinition Height="400" />
            <RowDefinition Height="5*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <TextBlock x:Name="tbFilename" Text="Filename" FontWeight="Bold" />

        <DataGrid x:Name="dgProperties" Grid.Row="1" MinWidth="300" AutoGenerateColumns="True"
                  Margin="0,0,0,0" GridLinesVisibility="None" Background="{x:Null}" />

        <Button x:Name="Cancel" Content="OK" Grid.Row="2" HorizontalAlignment="Right" Margin="0,15,11,8"
                VerticalAlignment="Bottom" Width="75" Click="OK_Click" IsDefault="True" IsCancel="True" />
    </Grid>
</Window>
